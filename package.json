{
  "name": "app-validator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm-run-all --parallel start:server start:client",
    "start:client": "ng serve",
    "start:server": "node server/server.mjs",
    "build": "ng build",
    "test:backend": "node --test server/**/*.test.mjs",
    "test:frontend:unit": "tsx --test src/**/*.test.ts",
    "test:frontend:typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test:frontend": "npm-run-all test:frontend:unit test:frontend:typecheck",
    "test": "npm-run-all test:backend test:frontend",
    "verify:major-change": "npm-run-all test build"
  },
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/router": "^19.2.0",
    "express": "^4.21.2",
    "oracledb": "^6.10.0",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
